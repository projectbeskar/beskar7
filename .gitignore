*.exe
*.exe~
*.dll
*.so
*.dylib
# Anchored to the repo root so we ignore the built binary `./manager` without
# accidentally hiding everything under `cmd/manager/` (which was matched by
# the unanchored rule, blocking new files in that directory).
/manager

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Go workspace directory
/vendor/

# Env file
.env*

# Build directory
/bin/
/out/

# IDE settings folders
.idea/
.vscode/

# Local development tooling configuration (per-developer, not shared)
/.claude/
/CLAUDE.md

